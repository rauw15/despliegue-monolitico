# Configuración de la Base de Datos
DATABASE_URL=postgres://postgres:password@localhost:5432/despliegue_monolitico

# Configuración JWT
JWT_SECRET=tu-clave-secreta-super-segura-aqui

# Configuración de la Aplicación
NODE_ENV=development
PORT=3000

# Configuración para Producción (usar en EC2)
POSTGRES_DB=despliegue_monolitico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu-password-postgres-seguro

# Configuración Docker
DOCKER_IMAGE=tu-usuario/despliegue-monolitico:latest

# Configuración Redis (opcional)
REDIS_URL=redis://localhost:6379
