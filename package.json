{
  "name": "despliegue-monolitico",
  "version": "1.0.0",
  "description": "Proyecto de ejemplo para despliegue monolítico con CI/CD",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
